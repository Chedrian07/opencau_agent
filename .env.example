# === LLM backend ===
# openai-native | lmstudio-responses | vllm-responses | ollama-stateless | mock
LLM_PROFILE=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1
# openai_computer | function_computer
LLM_TOOL_MODE=openai_computer
# server: previous_response_id 사용 / manual: 매 turn마다 history 재구성
LLM_STATE_MODE=server
LLM_SUPPORTS_VISION=true
LLM_SUPPORTS_TOOL_CALLS=true
LLM_HISTORY_WINDOW=12
LLM_REQUEST_TIMEOUT_SEC=120

# === Display ===
DISPLAY_WIDTH=1920
DISPLAY_HEIGHT=1080
DISPLAY_DEPTH=24

# === Agent ===
MAX_AGENT_STEPS=20
AGENT_TIMEOUT_SEC=600
ACTION_TIMEOUT_SEC=10
SCREENSHOT_DETAIL=original
REPEATED_ACTION_THRESHOLD=3

# === Sandbox ===
SANDBOX_IMAGE=opencau-agent-sandbox:latest
SANDBOX_IDLE_TIMEOUT_SEC=1800
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_CPUS=2.0
SANDBOX_PIDS_LIMIT=512
SANDBOX_START_TIMEOUT_SEC=30
SANDBOX_NETWORK=opencau_agent_internal

# === Storage ===
REDIS_URL=redis://redis:6379/0
SQLITE_PATH=/data/opencau-agent.sqlite
SCREENSHOT_DIR=/data/screenshots
SCREENSHOT_RETENTION_HOURS=24

# === Service URLs ===
SANDBOX_CONTROLLER_URL=http://sandbox-controller:8100
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
